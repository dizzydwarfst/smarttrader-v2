# SmartTrader Bot v2.0 Configuration (OANDA)
# Copy this file to .env and edit with your values

# ─── OANDA Credentials (REQUIRED) ───────────────────────
OANDA_API_KEY=paste-your-api-token-here
OANDA_ACCOUNT_ID=101-002-38937985-001

# ─── Claude AI (OPTIONAL — for AI advisor feature) ──────
# Get from: console.anthropic.com → API Keys
CLAUDE_API_KEY=
AI_LEARNING_ENABLED=true
AI_MODE=shadow
AI_MODEL=claude-sonnet-4-20250514
AI_MIN_CONFIDENCE=normal
AI_MIN_SIZE_MULT=0.25
AI_MAX_SIZE_MULT=1.25

# ─── Trading Mode ───────────────────────────────────────
# "practice" = paper trading (safe), "live" = real money (careful!)
TRADING_MODE=practice
PRACTICE_STYLE=standard
PRACTICE_BAR_GRANULARITY=M5
PRACTICE_POLL_INTERVAL=10
PRACTICE_FAST_EMA=5
PRACTICE_SLOW_EMA=13
PRACTICE_BREAKOUT_LOOKBACK=10
PRACTICE_BREAKOUT_VOLUME_MULT=1.0
PRACTICE_RISK_PER_TRADE=0.03
PRACTICE_MAX_POSITIONS=4
PRACTICE_DAILY_LOSS_LIMIT=0.06
PRACTICE_SPREAD_LIMIT_MULT=2.5
USE_VIRTUAL_BANKROLL=true
VIRTUAL_BANKROLL=1000
VIRTUAL_BANKROLL_FLOOR=250
VIRTUAL_RISK_PER_TRADE=0.005

# ─── Strategy Selection ─────────────────────────────────
# Which strategies to run. Available:
# ema, breakout, vwap_bounce, rsi_exhaustion
# Example test basket:
# STRATEGIES=ema,breakout,vwap_bounce,rsi_exhaustion
STRATEGIES=ema,breakout

# ─── EMA Strategy Parameters ────────────────────────────
FAST_EMA=9
SLOW_EMA=21

# ─── Breakout Strategy Parameters ───────────────────────
# How many candles to look back for support/resistance
BREAKOUT_LOOKBACK=20
# Minimum ATR multiplier for a valid breakout
BREAKOUT_ATR_THRESHOLD=0.5
# Volume confirmation multiplier (1.5 = 50% above average)
BREAKOUT_VOLUME_MULT=1.2

# VWAP Bounce Parameters
VWAP_BIAS_EMA=100
VWAP_VOLUME_LOOKBACK=20
VWAP_VOLUME_MULT=1.2
VWAP_WICK_RATIO=1.5

# RSI Exhaustion Parameters
RSI_EXHAUSTION_PERIOD=14
RSI_EXHAUSTION_OVERBOUGHT=85
RSI_EXHAUSTION_OVERSOLD=15
RSI_EXHAUSTION_STREAK_MIN=4

# ─── Candle Settings ────────────────────────────────────
# Granularity: M1, M5, M15, M30, H1, H4, D
BAR_GRANULARITY=M15
HISTORY_COUNT=200

# ─── Risk Management ────────────────────────────────────
RISK_PER_TRADE=0.02
MAX_POSITIONS=3
STOP_LOSS_ATR_MULT=1.5
TAKE_PROFIT_ATR_MULT=3.0
DAILY_LOSS_LIMIT=0.05
SPREAD_FILTER_ENABLED=true
SPREAD_LIMIT_MULT=1.0

# ─── News Filter ────────────────────────────────────────
NEWS_FILTER_ENABLED=true
# Minutes before/after high-impact news to stop trading
NEWS_BLACKOUT_BEFORE=30
NEWS_BLACKOUT_AFTER=15
NEWS_CALENDAR_SOURCE=tradingeconomics
TRADINGECONOMICS_API_KEY=guest:guest

# ─── Learning Engine ────────────────────────────────────
LEARNING_ENABLED=true
LEARNING_DAY=adaptive
MIN_TRADES_FOR_LEARNING=5
LEARNING_LOOKBACK_WEEKS=2
LEARNING_IMPROVEMENT_THRESHOLD=0.05
LEARNING_COOLDOWN_MINUTES=180
LEARNING_MIN_NEW_TRADES=3

# ─── Instruments ─────────────────────────────────────────
INSTRUMENTS=XAU_USD,XAG_USD,USD_JPY,EUR_USD,GBP_USD,AUD_USD,EUR_JPY

# ─── Bot Timing ──────────────────────────────────────────
POLL_INTERVAL=30
CANDLE_REFRESH_MIN_SECONDS=30
PRICE_CACHE_TTL_SECONDS=8
API_ERROR_COOLDOWN_SECONDS=25

# ─── Dashboard API ───────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
AUTO_START_DASHBOARD=true

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO
DB_PATH=trades.db
BOT_STATUS_PATH=bot_status.json
SOUL_PATH=soul.md
SKILLS_PATH=skills.md

# ─── Telegram Alerts (OPTIONAL) ──────────────────────────
# 1. Talk to @BotFather on Telegram → /newbot → copy the token.
# 2. Send any message to your new bot, then visit
#      https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find the "chat":{"id":...} field. That's your chat id.
# 3. Leave both blank to disable alerts entirely (bot is unaffected).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
